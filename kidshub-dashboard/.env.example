VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# URL of the transactional email API (kidshub-landing serverless functions).
# Overrides the default of https://getkidshub.com. Set this in Vercel for
# preview/prod if you host /api elsewhere, or in .env.local to point at a
# local `vercel dev` while hacking on the email templates.
VITE_EMAIL_API_URL=https://getkidshub.com

# Kidshub app base URL — used to build /invite/{token} links inside emails.
# Same var already consumed by the invite modals; keep it in sync.
VITE_KIDSHUB_APP_URL=https://app.getkidshub.com
