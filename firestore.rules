rules_version = '2';

// =============================================================================
// KidsHub Firestore Security Rules — p3-15 role-scoped + multi-tenant ruleset
// =============================================================================
//
// Source of truth: this file. Keep rules in git, not just in the Firebase
// Console, so changes are reviewable and auditable.
//
// To deploy:
//   1. Open https://console.firebase.google.com/project/kidhub-7a207/firestore/rules
//   2. Paste the contents of this file into the rules editor.
//   3. Click "Publish". Changes take effect within ~60 seconds.
//
// (Future: Phase 4 will wire up `firebase deploy --only firestore:rules` via
//  a proper `firebase.json` + firebase-tools in CI, so editing this file and
//  pushing to main auto-deploys. See p4-3.)
//
// =============================================================================
// Tenant model (p3-15)
// =============================================================================
//
// Every business doc (children/classrooms/staff/activities/messages/parents/
// announcements) carries a `daycareId` field. Every user doc carries a role
// and role-specific scoping fields:
//
//   role='owner'    → daycareId = own uid                              (1:1)
//   role='teacher'  → daycareId + classroomId (both set at invite-accept)
//   role='parent'   → daycareId (null until an owner links the 1st child)
//                   + childIds[] (list of children they can see)
//
// These fields are the ONLY way a non-owner user is granted access to a
// business doc. Rules read them off the requester's users/{uid} doc on
// every evaluation via the `userDoc()` helper.
//
// Multi-tenant isolation: an owner can only read/write docs whose
// daycareId == their own uid. Cross-tenant access is impossible.
//
// Legacy docs without daycareId are INTENTIONALLY unreadable after this
// ruleset ships — this is a clean-slate pilot. If there's existing test
// data that needs to keep working, run a one-off backfill stamping
// `daycareId = ownerUid` on every doc before publishing these rules.
//
// =============================================================================
// Option B: Staff ↔ Teacher linkage (Oct 2026)
// =============================================================================
//
// Staff records (staff/{id}) are the source of truth for who works at a
// daycare. Teacher app accounts (users with role='teacher') are an OPT-IN
// overlay granted by the owner via an invite. The link flows:
//
//   1. Owner creates staff/{sid} with { appStatus:'none', linkedUserId:null }.
//   2. Owner clicks "Invite to app" on that staff card — dashboard writes
//      invites/{token} with staffId=sid + updates staff.appStatus='invited'.
//   3. Teacher accepts invite in kidshub app:
//      a. setDoc(users/{uid}) with role='teacher', linkedStaffId=sid,
//         daycareId, classroomId (all pulled from invite)
//      b. updateDoc(staff/{sid}) with linkedUserId=uid, appStatus='active'
//         (permitted by the teacher update branch below — scoped to their
//         own staff record by email match)
//      c. deleteDoc(invites/{token})
//   4. If owner revokes a pending invite, dashboard resets
//      staff.appStatus='none' in the same batch.
//
// Staff delete is client-side blocked (dashboardUX) when linkedUserId is
// set — the owner must revoke app access first. Hard-deleting a linked
// staff record would leave the user's session live with dangling state.
//
// =============================================================================
// Owner ↔ Parent linkage (Option B for parents)
// =============================================================================
//
// Parent onboarding mirrors teacher onboarding exactly. Canonical flow:
//
//   1. Owner creates parents/{pid} in the dashboard — a pre-user contact
//      record with firstName/lastName/email/phone/childIds[]. Seeded with
//      { appStatus:'none', linkedUserId:null } (mirror of staff record).
//   2. Owner clicks "Invite to app" on that parent card — dashboard writes
//      invites/{token} with role='parent', parentId=pid, childId=<primary>,
//      and updates parents.appStatus='invited'.
//   3. Parent accepts invite in kidshub app (/invite/{token}):
//      a. setDoc(users/{uid}) with role='parent', linkedParentId=pid,
//         daycareId, childIds=<parents/{pid}.childIds> (ALL siblings in
//         the parent record are linked in one pass — this is the multi-
//         child property that makes parent onboarding differ from 1:1
//         teacher-to-classroom).
//      b. updateDoc(parents/{pid}) with linkedUserId=uid, appStatus='active'
//         (permitted by the parent update branch below — scoped to their
//         own parent record by email match).
//      c. updateDoc(children/{childId}) arrayUnion uid into parentIds
//         (one per sibling), which unlocks the per-child read rule.
//      d. deleteDoc(invites/{token}).
//   4. If owner revokes a pending parent invite, dashboard resets
//      parents.appStatus='none' in the same batch.
//
// Parent data access after link:
//   - users/{uid}.childIds is the primary surface that gates parent access
//     to child-scoped business data (activities, messages, photos,
//     healthLogs, screenings). Each of those rules joins on
//     `resource.data.childId in userChildIds()` — a FIELD-level check that
//     Firestore's list-query evaluator can prove from the client's
//     `where('childId', '==', <id>)` filter.
//   - For the children collection itself the parent-read check is
//     `request.auth.uid in resource.data.parentIds` only (no path-id
//     join). This is an intentional asymmetry and it is required to make
//     `where('parentIds', 'array-contains', uid)` queries pass Firestore's
//     rule evaluator. See the long-form comment on
//     `match /children/{childId}` for the safety argument — TL;DR:
//     `parentIds` is only ever populated through owner writes or through
//     the parent-self-link UPDATE rule, and that update rule DOES still
//     enforce `childId in userChildIds()`, so `uid in parentIds` is a
//     provably legitimate link.
//   - Net invariant: a parent can only ever see documents for children
//     they are actually linked to (via users.childIds and/or
//     children.parentIds, kept in sync by the accept flow + rules).
//   - No "parent self-signup" UI is exposed anywhere in the apps; the code
//     path in AuthContext.registerParent is unreachable from end-user UI
//     and is kept for future pre-existing-account recovery edge cases.
//     Even if exercised, it creates a dormant account with childIds=[] and
//     daycareId=null — zero data access until an owner or invite links it.
//
// Legacy owner-linking of a bare parent user (older usersApi.linkParentToChild)
// is still supported by the rules below (owner can patch childIds + daycareId
// + updatedAt on a users/{parent} doc), but the canonical path is the
// invite-only Option B flow above.
//
// =============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helper functions
    // -------------------------------------------------------------------------

    function isAuthenticated() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // The requester's own users/{uid} doc. Callers must gate with exists()
    // (via isOwner/isTeacher/isParent) before accessing fields, or they risk
    // rule evaluation errors when the user has no profile doc yet.
    //
    // Firestore dedupes identical get() calls within a single rule evaluation,
    // so repeated userDoc() reads count as one operation against the 10-op
    // per-rule limit.
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userRole() {
      return userDoc().role;
    }

    function userDaycare() {
      return userDoc().get('daycareId', '');
    }

    function userClassroom() {
      return userDoc().get('classroomId', '');
    }

    function userChildIds() {
      return userDoc().get('childIds', []);
    }

    function hasProfile() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isOwner()   { return hasProfile() && userRole() == 'owner'; }
    function isTeacher() { return hasProfile() && userRole() == 'teacher'; }
    function isParent()  { return hasProfile() && userRole() == 'parent'; }

    function isValidRole(role) {
      return role in ['owner', 'teacher', 'parent'];
    }

    // -------------------------------------------------------------------------
    // Plan / entitlements helpers (Sprint 3 / A7)
    // -------------------------------------------------------------------------
    //
    // These mirror `config/product.ts`'s TIER_ORDER + FEATURES maps. When
    // you add a new paid feature, (a) add the key to FEATURES in config/
    // product.ts, and (b) add a branch to `planAllows()` below. Rules and
    // client config must agree — there's no auto-sync.
    //
    // `planAllows(feature)` is the server-side defense against a client
    // compromise calling a paid-feature write. Layer it into the relevant
    // `allow create`/`allow update` expressions, e.g.:
    //
    //   match /photos/{photoId} {
    //     allow create: if isAuthenticated()
    //       && inMyTenant(request.resource.data)
    //       && planAllows('photoJournal');
    //   }
    //
    // Why read centers/{daycareId} every call? Firestore dedupes identical
    // get() reads inside a single rule evaluation, so `centerDoc()` costs
    // one extra read per rule — worth it for the safety.
    //
    // Tier satisfaction uses numeric ranks (matches TIER_ORDER):
    //   starter=0 · pro=1 · premium=2 · trial=2 (trial == premium while active)
    //
    // Trial expiry: rules do NOT enforce trialEndsAt. The client lazy-
    // downgrades via `useEntitlements()` (A9), so a compromised client
    // could theoretically keep writing as trial past its end. That's
    // acceptable today — first-customer billing enforcement is Track F.

    function centerDoc() {
      return get(/databases/$(database)/documents/centers/$(userDaycare())).data;
    }

    function currentPlan() {
      // Default to 'starter' if plan is missing (legacy / unstamped centers).
      // `planAllows()` then gates paid features strictly.
      return centerDoc().get('plan', 'starter');
    }

    function demoMode() {
      return centerDoc().get('demoMode', false);
    }

    // Maps a tier string to its capability rank. Higher == more features.
    // Keep in sync with TIER_ORDER in config/product.ts.
    function tierRank(tier) {
      return tier == 'premium' ? 2
        : tier == 'trial' ? 2
        : tier == 'pro' ? 1
        : 0; // 'starter' or unknown
    }

    // Effective rank for gating. Demo mode always passes every check.
    function effectiveTierRank() {
      return demoMode() ? 2 : tierRank(currentPlan());
    }

    // Minimum tier rank required for a feature. Mirrors FEATURES in
    // config/product.ts.
    function requiredRankFor(feature) {
      // core.* features unlock at starter (rank 0).
      return feature == 'photoJournal' ? 1
        : feature == 'dailyReports' ? 1
        : feature == 'attendanceReports' ? 1
        : feature == 'healthReports' ? 1
        : feature == 'staffClockIn' ? 1
        : feature == 'morningScreenings' ? 1
        : feature == 'weeklyPlanner' ? 1
        : feature == 'activityPlanner' ? 1
        : feature == 'customBranding' ? 1
        : feature == 'emailSupport' ? 1
        : feature == 'multiDaycare' ? 2
        : feature == 'ariaAiInApp' ? 2
        : feature == 'apiAccess' ? 2
        : feature == 'dedicatedSupport' ? 2
        : 0; // core.* and unknown features default to starter
    }

    // Server-side feature gate. Use on paid-feature creates/updates.
    // Requires the requester to have a profile (so userDaycare() resolves)
    // and a center doc with a known plan. Returns false for un-profiled
    // or unknown-plan users — fails closed.
    function planAllows(feature) {
      return hasProfile()
        && effectiveTierRank() >= requiredRankFor(feature);
    }

    // Business-doc tenant check. Returns true iff the doc's daycareId
    // matches the requester's daycareId. Legacy docs without daycareId
    // return false → unreadable (intentional clean-slate enforcement).
    function inMyTenant(data) {
      return 'daycareId' in data && data.daycareId == userDaycare();
    }

    // Children may use either `classroomId` (canonical) or `classroom`
    // (legacy field name still present in some dashboard code paths).
    // Accept both until the legacy field is renamed.
    function childClassroom(data) {
      return data.get('classroomId', data.get('classroom', ''));
    }

    // -------------------------------------------------------------------------
    // users/{uid} — profile + role + scoping fields
    // -------------------------------------------------------------------------
    //
    // Read:
    //   - self (always)
    //   - owner reading another user in their tenant (for linkParentToChild,
    //     dashboard Parents/Staff pages going forward, etc.)
    //
    // Create (self-signup): role-specific scoping enforcement.
    //   - owner  → daycareId MUST equal own uid (1 owner = 1 daycare)
    //   - parent → daycareId MUST NOT be set (owners seed it on first link)
    //   - teacher → daycareId + classroomId MUST match the invite doc;
    //              invite must exist + have matching email + role=teacher
    //
    // Update:
    //   - self (profile edits): role/uid/daycareId/childIds all frozen
    //   - owner linking a parent: may only change
    //       {childIds, daycareId, updatedAt}
    //     and only on parent users whose daycareId is null or already == own uid
    //
    // Delete: never from client (Admin SDK path for future soft-delete).
    //
    match /users/{userId} {
      allow read: if isSelf(userId)
        || (isOwner() && inMyTenant(resource.data));

      allow create: if isSelf(userId)
        && isValidRole(request.resource.data.role)
        && (
          // Owner self-signup: daycareId must equal own uid.
          (
            request.resource.data.role == 'owner'
            && request.resource.data.daycareId == userId
          )
          // Parent self-signup (dormant account): daycareId must NOT be set.
          // The account exists but has no data access until an owner links
          // it to a child via usersApi.linkParentToChild.
          || (
            request.resource.data.role == 'parent'
            && !('daycareId' in request.resource.data)
          )
          // Parent invite-accept (p3-20): daycareId + childIds must match
          // the invite. Stamps childIds[inviteChildId] so the parent can
          // immediately see that child's data without a second owner step.
          || (
            request.resource.data.role == 'parent'
            && request.resource.data.inviteToken is string
            && exists(/databases/$(database)/documents/invites/$(request.resource.data.inviteToken))
            && get(/databases/$(database)/documents/invites/$(request.resource.data.inviteToken)).data.role == 'parent'
            && get(/databases/$(database)/documents/invites/$(request.resource.data.inviteToken)).data.email == request.auth.token.email
            && request.resource.data.daycareId == get(/databases/$(database)/documents/invites/$(request.resource.data.inviteToken)).data.daycareId
            && request.resource.data.childIds is list
            && get(/databases/$(database)/documents/invites/$(request.resource.data.inviteToken)).data.childId in request.resource.data.childIds
          )
          // Teacher invite-accept: daycareId + classroomId must match invite.
          // If the invite has a staffId (Option B), the new user doc's
          // linkedStaffId must match it so the teacher is unambiguously tied
          // to the staff roster record they were invited against.
          || (
            request.resource.data.role == 'teacher'
            && request.resource.data.inviteToken is string
            && exists(/databases/$(database)/documents/invites/$(request.resource.data.inviteToken))
            && get(/databases/$(database)/documents/invites/$(request.resource.data.inviteToken)).data.role == 'teacher'
            && get(/databases/$(database)/documents/invites/$(request.resource.data.inviteToken)).data.email == request.auth.token.email
            && request.resource.data.daycareId == get(/databases/$(database)/documents/invites/$(request.resource.data.inviteToken)).data.daycareId
            && request.resource.data.classroomId == get(/databases/$(database)/documents/invites/$(request.resource.data.inviteToken)).data.classroomId
            && (
              // Option B path — invite has staffId, linkedStaffId must match.
              (
                get(/databases/$(database)/documents/invites/$(request.resource.data.inviteToken)).data.get('staffId', '') != ''
                && request.resource.data.get('linkedStaffId', '') == get(/databases/$(database)/documents/invites/$(request.resource.data.inviteToken)).data.staffId
              )
              // Legacy path — pre-Option-B invite with no staffId.
              // linkedStaffId must be absent so we don't forge a link to
              // an arbitrary staff record.
              || (
                get(/databases/$(database)/documents/invites/$(request.resource.data.inviteToken)).data.get('staffId', '') == ''
                && !('linkedStaffId' in request.resource.data)
              )
            )
          )
        );

      allow update: if
        // Self profile edit — frozen fields cannot be touched.
        (
          isSelf(userId)
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
            'role', 'uid', 'daycareId', 'childIds', 'classroomId', 'inviteToken', 'invitedBy'
          ])
        )
        // Owner linking a parent — may only touch {childIds, daycareId, updatedAt}
        // and only on parent users without a conflicting existing daycareId.
        || (
          isOwner()
          && resource.data.role == 'parent'
          && request.resource.data.role == resource.data.role
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.daycareId == request.auth.uid
          && (
            resource.data.get('daycareId', '') == ''
            || resource.data.get('daycareId', '') == request.auth.uid
          )
          && request.resource.data.diff(resource.data)
              .affectedKeys().hasOnly(['childIds', 'daycareId', 'updatedAt'])
        );

      allow delete: if false;
    }

    // -------------------------------------------------------------------------
    // invites/{token} — pending teacher + parent invites (p3-14, p3-20)
    // -------------------------------------------------------------------------
    //
    // Two invite flavours share this collection; they differ by role + the
    // associated scoping field:
    //   role='teacher' → classroomId (which classroom the teacher joins)
    //   role='parent'  → childId     (which child the parent is linked to)
    //
    // Common constraints for both:
    //   - invitedBy  must equal the owner's uid (forgery-proof)
    //   - daycareId  must equal the owner's uid (can't invite into another tenant)
    //   - email      must be a string (locked at creation; accept-time check
    //                  in users create rule re-verifies against auth.token.email)
    //
    match /invites/{token} {
      allow read: if true;

      // Teacher invites (Option B) carry `staffId` pointing at the pre-existing
      // staff/{id} roster record. The accept flow then flips staff.appStatus
      // to 'active' + links linkedUserId. Field is required on new teacher
      // invites; existing pre-Option-B invites without it are still honored
      // by accept (linkedStaffId just stays null on the teacher's users doc).
      //
      // Parent invites (mirror of Option B for parents) carry:
      //   - childId       — REQUIRED, the primary child the parent is being
      //     introduced to (used for the accept-screen banner: "You're invited
      //     to connect with {childName}"). Always present for rule compat
      //     with the legacy ChildProfile path.
      //   - parentId      — OPTIONAL, pointer at the pre-existing parents/{id}
      //     contact roster record (new in this step). When present, the
      //     accept flow (acceptParentInvite in AuthContext) reads the parent
      //     record's childIds[] and stamps ALL of them on users/{uid}.childIds
      //     so siblings are linked in one pass. When absent, the accept flow
      //     falls back to the legacy single-child path (childId only).
      //   Keeping parentId optional is intentional: existing in-flight invites
      //   from before this rollout must still be redeemable, and the
      //   ChildProfile page's legacy "Invite parent to app" button doesn't
      //   pass parentId until it's rewired in Step 6.
      allow create: if isOwner()
        && request.resource.data.invitedBy == request.auth.uid
        && request.resource.data.daycareId == request.auth.uid
        && request.resource.data.email is string
        && (
          (request.resource.data.role == 'teacher'
            && request.resource.data.classroomId is string
            && request.resource.data.staffId is string)
          || (request.resource.data.role == 'parent'
            && request.resource.data.childId is string)
        );

      allow delete: if isAuthenticated()
        && (
          // Inviter revoking their own invite.
          (isOwner() && request.auth.uid == resource.data.invitedBy)
          // Invitee consuming the invite during accept.
          || request.auth.token.email == resource.data.email
        );

      allow update: if false;
    }

    // -------------------------------------------------------------------------
    // centers/{ownerId} — 1:1 tenant metadata keyed by owner uid
    // -------------------------------------------------------------------------
    //
    // Read:
    //   - owner: their own center doc
    //   - teacher: the center doc of the daycare they belong to (needed so
    //              useEntitlements() in the kidshub app can read plan /
    //              demoMode / feature flags on the teacher side)
    //   - parent:  same rationale as teacher — parents need plan visibility
    //              to correctly show upgrade CTAs on gated features
    //
    // Write: owner only. Parent/teacher cannot modify the center doc
    //        (including demoMode). Client-side admin-UID gating on the
    //        Settings toggle is a UX refinement, not a security boundary —
    //        the boundary is this rule.
    //
    match /centers/{ownerId} {
      allow read: if (isSelf(ownerId) && isOwner())
        || (isTeacher() && userDaycare() == ownerId)
        || (isParent()  && userDaycare() == ownerId);
      allow write: if isSelf(ownerId) && isOwner();
    }

    // -------------------------------------------------------------------------
    // children/{childId}
    // -------------------------------------------------------------------------
    //
    // Read:
    //   - owner: any child in their tenant
    //   - teacher: children in their classroom (classroomId OR legacy classroom)
    //   - parent: children whose parentIds[] includes the parent's uid
    //
    // Why the parent-read check is ONLY `uid in parentIds` (not ALSO
    // `childId in userChildIds()`):
    //   The kidshub parent home subscribes via
    //     `where('parentIds', 'array-contains', uid)`
    //   Firestore's list-query rule evaluator requires that the query's
    //   filters prove the rule is satisfied for every possible returned
    //   doc — using the doc-id placeholder `childId` on the RHS of a
    //   condition (as in `childId in userChildIds()`) cannot be proven
    //   from a non-id filter, so the whole query is rejected with
    //   `permission-denied` at query time. Dropping the doc-id check
    //   here fixes listing WITHOUT widening access, because:
    //     (a) `parentIds` is written only by owner/admin paths, or by
    //         the parent self-link UPDATE rule below, which still
    //         enforces `childId in userChildIds()`.
    //     (b) A parent cannot add themselves to an arbitrary child's
    //         `parentIds` without first having that childId in their
    //         own users doc (see the update rule below).
    //   So if `uid in parentIds` is already true, the link is provably
    //   legitimate and the read is safe. The former belt-and-suspenders
    //   check was defending against a scenario the write rules already
    //   forbid.
    //
    // Create: owner only. Must stamp daycareId == own uid + parentIds[] list.
    //
    // Update:
    //   - owner: any field, within tenant
    //   - teacher: ONLY check-in/out fields on children in their classroom,
    //              and may not change daycareId
    //   - parent: self-link only (parentIds arrayUnion own uid); still
    //             gated by `childId in userChildIds()` — that check is
    //             FINE on updates because the client targets a specific
    //             doc id, not a list query.
    //
    // Delete: owner only.
    //
    match /children/{childId} {
      allow read: if (isOwner() && inMyTenant(resource.data))
        || (isTeacher() && inMyTenant(resource.data)
            && childClassroom(resource.data) == userClassroom())
        || (isParent()
            && request.auth.uid in resource.data.get('parentIds', []));

      allow create: if isOwner()
        && request.resource.data.daycareId == request.auth.uid
        && request.resource.data.parentIds is list;

      allow update: if (isOwner() && inMyTenant(resource.data))
        || (
          isTeacher()
          && inMyTenant(resource.data)
          && childClassroom(resource.data) == userClassroom()
          && request.resource.data.daycareId == resource.data.daycareId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status', 'checkInTime', 'checkOutTime',
            'lastCheckInBy', 'lastCheckInNotes',
            'lastCheckOutBy', 'lastCheckOutNotes',
            'updatedAt'
          ])
        )
        // Parent self-link (p3-20). After accepting an invite, the parent
        // writes users/{uid} with childIds=[thisChildId], then writes
        // children/{thisChildId}.parentIds to include their own uid so the
        // parent read rule (`uid in parentIds`) unlocks. Constraints:
        //   - parent must already have this childId in their users doc
        //     (set by the invite-accept setDoc one step earlier)
        //   - only parentIds + updatedAt may be modified
        //   - daycareId must not change
        //   - the parent must be adding themselves
        //   - no existing parent link may be removed (subset check)
        || (
          isParent()
          && inMyTenant(resource.data)
          && childId in userChildIds()
          && request.resource.data.daycareId == resource.data.daycareId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'parentIds', 'updatedAt'
          ])
          && request.auth.uid in request.resource.data.parentIds
          && resource.data.get('parentIds', []).toSet()
              .difference(request.resource.data.parentIds.toSet()).size() == 0
        );

      allow delete: if isOwner() && inMyTenant(resource.data);
    }

    // -------------------------------------------------------------------------
    // classrooms/{classroomId}
    // -------------------------------------------------------------------------
    match /classrooms/{classroomId} {
      allow read: if (isOwner() && inMyTenant(resource.data))
        || (isTeacher() && inMyTenant(resource.data) && classroomId == userClassroom())
        || (isParent() && inMyTenant(resource.data));

      allow create: if isOwner()
        && request.resource.data.daycareId == request.auth.uid;

      allow update, delete: if isOwner() && inMyTenant(resource.data)
        && request.resource.data.daycareId == resource.data.daycareId;
    }

    // -------------------------------------------------------------------------
    // staff/{staffId} — legacy owner-managed employee roster
    // -------------------------------------------------------------------------
    //
    // This collection is the dashboard's record of employees-on-payroll.
    // Separate from `users where role='teacher'` (which are app accounts).
    // Phase 4 cleanup will reconcile these — for now, owners manage staff,
    // teachers can see their co-workers in the same daycare.
    //
    match /staff/{staffId} {
      // Parents may list staff within their own tenant — the kidshub
      // parent Messages tab needs this to resolve the classroom teacher
      // to chat with. The list query is
      //   `where('daycareId', '==', profile.daycareId)`
      // which proves `inMyTenant` to the rule evaluator. UI filters
      // down to the parent's child's classroom. Staff docs hold
      // employment metadata (name, email, role, classroom) — no SSN /
      // payroll fields live here, so tenant-scoped parent visibility
      // is the intended product behavior.
      allow read: if (isOwner() && inMyTenant(resource.data))
        || (isTeacher() && inMyTenant(resource.data))
        || (isParent() && inMyTenant(resource.data));

      allow create: if isOwner()
        && request.resource.data.daycareId == request.auth.uid;

      // Option B: a freshly-registered teacher flips their linked staff
      // record from appStatus='invited' → 'active' and stamps
      // linkedUserId=self.uid. Scoped down to:
      //   - requester is a teacher in the same tenant
      //   - the staff record's email matches their auth email (strong link
      //     from the staff roster to the invite to the Firebase Auth account)
      //   - only {linkedUserId, appStatus, updatedAt} change — name/role/
      //     classroom etc. are frozen
      //   - linkedUserId must be the requester themselves
      //   - record isn't already linked to someone else
      allow update: if (isOwner() && inMyTenant(resource.data)
          && request.resource.data.daycareId == resource.data.daycareId)
        || (
          isTeacher()
          && inMyTenant(resource.data)
          && resource.data.email == request.auth.token.email
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'linkedUserId', 'appStatus', 'updatedAt'
          ])
          && request.resource.data.linkedUserId == request.auth.uid
          && request.resource.data.appStatus == 'active'
          && (
            resource.data.get('linkedUserId', null) == null
            || resource.data.linkedUserId == request.auth.uid
          )
        );

      allow delete: if isOwner() && inMyTenant(resource.data);
    }

    // -------------------------------------------------------------------------
    // activities/{activityId}
    // -------------------------------------------------------------------------
    //
    // Read:
    //   - owner: any in tenant
    //   - teacher: any in their classroom
    //   - parent: any where childId ∈ parent's childIds
    //
    // Create:
    //   - owner: must stamp daycareId == own uid + valid classroomId string
    //   - teacher: must stamp daycareId == own daycareId
    //              + classroomId == own classroomId
    //              + staffId == own uid
    //     (guarantees a teacher can only log activities for their class, and
    //      can't attribute them to another staff member)
    //
    // Update/delete: owner only. Activities are an audit trail.
    //
    match /activities/{activityId} {
      allow read: if (isOwner() && inMyTenant(resource.data))
        || (isTeacher() && inMyTenant(resource.data)
            && resource.data.get('classroomId', '') == userClassroom())
        || (isParent() && resource.data.childId in userChildIds());

      allow create: if (
          isOwner()
          && request.resource.data.daycareId == request.auth.uid
          && request.resource.data.classroomId is string
        )
        || (
          isTeacher()
          && request.resource.data.daycareId == userDaycare()
          && request.resource.data.classroomId == userClassroom()
          && request.resource.data.staffId == request.auth.uid
        );

      allow update, delete: if isOwner() && inMyTenant(resource.data);
    }

    // -------------------------------------------------------------------------
    // messages/{messageId}
    // -------------------------------------------------------------------------
    //
    // Read:
    //   - owner: any in tenant
    //   - participants (sender or recipient) within same tenant
    //
    // Create: authenticated user stamping themselves as sender + their own
    //         daycareId. Prevents impersonation and cross-tenant message
    //         injection.
    //
    // Update: recipient marking their received message as read (only `read`
    //         and `readAt` fields), OR owner editing any field in tenant.
    //
    // Delete: sender, or owner in tenant.
    //
    match /messages/{messageId} {
      allow read: if (isOwner() && inMyTenant(resource.data))
        || (
          inMyTenant(resource.data)
          && (
            resource.data.senderId == request.auth.uid
            || resource.data.recipientId == request.auth.uid
          )
        );

      // Two legitimate create paths:
      //   1. Normal: a signed-in user sends their own message (senderId == uid).
      //   2. Owner-in-tenant: owner writes messages on behalf of their daycare
      //      — used by the seed demo dataset (senderIds like 'parent-1') and
      //      future owner-broadcast / system-message features. Constrained to
      //      the owner's own tenant (daycareId == owner.uid) so an owner of
      //      daycare A can't inject messages into daycare B.
      allow create: if (
          isAuthenticated()
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.daycareId == userDaycare()
        )
        || (
          isOwner()
          && request.resource.data.daycareId == request.auth.uid
        );

      allow update: if (
          // Recipient marking as read.
          resource.data.recipientId == request.auth.uid
          && inMyTenant(resource.data)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'readAt'])
        )
        || (
          // Teacher archiving a thread they participate in (Sprint 4 / B6).
          // Scoped to staff — parents never touch these keys on their side.
          // Restricted to participants so one teacher can't re-file another
          // teacher's conversations.
          isTeacher()
          && inMyTenant(resource.data)
          && (
            resource.data.senderId == request.auth.uid
            || resource.data.recipientId == request.auth.uid
          )
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['archivedByStaff', 'staffArchivedAt'])
        )
        || (isOwner() && inMyTenant(resource.data));

      allow delete: if (resource.data.senderId == request.auth.uid && inMyTenant(resource.data))
        || (isOwner() && inMyTenant(resource.data));
    }

    // -------------------------------------------------------------------------
    // parents/{parentId} — owner-managed parent CONTACT ROSTER
    // -------------------------------------------------------------------------
    //
    // Direct structural mirror of staff/{staffId}. A `parents/{id}` doc is
    // the owner's pre-user contact record for a parent — it exists before
    // the parent has a Firebase Auth account, and lives through the invite
    // lifecycle (none → invited → active) identically to staff.
    //
    // Read:
    //   - owner: any record in their tenant
    //   - parent: their OWN record after self-link (scoped by linkedUserId).
    //     No other parent can read someone else's record — tenants are
    //     an owner-level boundary; within a tenant, parents are siloed.
    //
    // Create: owner only, must stamp daycareId == own uid.
    //
    // Update:
    //   - owner: any field in tenant, daycareId must not change.
    //   - parent self-link (mirror of staff self-link on lines ~546-559):
    //     a parent accepting their invite flips their own record to
    //     appStatus='active' + linkedUserId=self. Constraints:
    //       - requester is an authenticated parent in the same tenant
    //       - record.email matches request.auth.token.email  (strong link
    //         from the parent roster to the invite to the Firebase Auth
    //         account — email is the invariant across all three)
    //       - only {linkedUserId, appStatus, updatedAt} change (name /
    //         childIds / phone etc. are frozen from the parent's side)
    //       - linkedUserId must be the requester themselves
    //       - record isn't already linked to someone else (prevents a
    //         stolen-invite scenario where a different authed user tries
    //         to hijack the record)
    //
    // Delete: owner only. Dashboard UX should gate delete when
    //         appStatus='active' (analog of staff).
    //
    match /parents/{parentId} {
      allow read: if (isOwner() && inMyTenant(resource.data))
        || (isParent()
            && inMyTenant(resource.data)
            && resource.data.get('linkedUserId', null) == request.auth.uid);

      allow create: if isOwner()
        && request.resource.data.daycareId == request.auth.uid;

      allow update: if (isOwner() && inMyTenant(resource.data)
          && request.resource.data.daycareId == resource.data.daycareId)
        || (
          isParent()
          && inMyTenant(resource.data)
          && resource.data.email == request.auth.token.email
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'linkedUserId', 'appStatus', 'updatedAt'
          ])
          && request.resource.data.linkedUserId == request.auth.uid
          && request.resource.data.appStatus == 'active'
          && (
            resource.data.get('linkedUserId', null) == null
            || resource.data.linkedUserId == request.auth.uid
          )
        );

      allow delete: if isOwner() && inMyTenant(resource.data);
    }

    // -------------------------------------------------------------------------
    // announcements/{annId} — daycare-wide broadcasts
    // -------------------------------------------------------------------------
    match /announcements/{annId} {
      allow read: if (isOwner() && inMyTenant(resource.data))
        || (isTeacher() && inMyTenant(resource.data))
        || (isParent() && inMyTenant(resource.data));

      allow create: if (isOwner() && request.resource.data.daycareId == request.auth.uid)
        || (isTeacher() && request.resource.data.daycareId == userDaycare());

      allow update, delete: if isOwner() && inMyTenant(resource.data);
    }

    // -------------------------------------------------------------------------
    // photos/{photoId} — photo journal (Sprint 5 / D1)
    // -------------------------------------------------------------------------
    //
    // Pro-and-up feature. Binary content lives in Firebase Storage; this
    // collection stores metadata + `imageUrl` only. Photos can tag 1..N
    // children via `childIds[]` so group shots surface on every tagged
    // parent's gallery without duplicating the upload.
    //
    // Rules:
    //   - read: owner (tenant), teacher (tenant + classroom match), or
    //           parent whose linked childIds intersect the photo's tags
    //   - create: owner OR teacher in same tenant AND planAllows('photoJournal');
    //             uploadedBy must equal requester uid
    //   - update: uploader or owner — limited to caption / tags edits
    //   - delete: uploader or owner
    //
    match /photos/{photoId} {
      allow read: if (isOwner() && inMyTenant(resource.data))
        || (isTeacher() && inMyTenant(resource.data)
            && resource.data.get('classroomId', '') == userClassroom())
        || (isParent()
            && inMyTenant(resource.data)
            && resource.data.childIds.toSet()
                .intersection(userChildIds().toSet()).size() > 0);

      allow create: if planAllows('photoJournal')
        && request.resource.data.daycareId == userDaycare()
        && request.resource.data.uploadedBy == request.auth.uid
        && request.resource.data.childIds is list
        && request.resource.data.childIds.size() > 0
        && request.resource.data.imageUrl is string
        && (
          (isOwner() && request.resource.data.daycareId == request.auth.uid)
          || (isTeacher() && request.resource.data.classroomId == userClassroom())
        );

      allow update: if inMyTenant(resource.data)
        && planAllows('photoJournal')
        && (
          isOwner()
          || resource.data.uploadedBy == request.auth.uid
        )
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'caption', 'childIds', 'updatedAt'
        ]);

      allow delete: if inMyTenant(resource.data)
        && (isOwner() || resource.data.uploadedBy == request.auth.uid);
    }

    // -------------------------------------------------------------------------
    // attendance/{attendanceId} — staff clock-in (Sprint 6 / D4)
    // -------------------------------------------------------------------------
    //
    // Pro-and-up. Teachers clock themselves in/out; owners can see the
    // full daycare timesheet. Teachers can only edit their OWN open shift
    // (set clockOutAt). Once closed, the row is immutable for teachers.
    //
    match /attendance/{attendanceId} {
      allow read: if (isOwner() && inMyTenant(resource.data))
        || (isTeacher() && inMyTenant(resource.data)
            && resource.data.userId == request.auth.uid);

      allow create: if planAllows('staffClockIn')
        && isTeacher()
        && request.resource.data.daycareId == userDaycare()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.clockInAt is string
        && request.resource.data.get('clockOutAt', null) == null;

      allow update: if inMyTenant(resource.data)
        && planAllows('staffClockIn')
        && (
          // Teacher closing their own open shift.
          (
            isTeacher()
            && resource.data.userId == request.auth.uid
            && resource.data.get('clockOutAt', null) == null
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'clockOutAt', 'minutesWorked', 'notes', 'updatedAt'
            ])
          )
          || isOwner()
        );

      allow delete: if isOwner() && inMyTenant(resource.data);
    }

    // -------------------------------------------------------------------------
    // healthLogs/{logId} — compliance-oriented health log (Sprint 7 / D5)
    // -------------------------------------------------------------------------
    match /healthLogs/{logId} {
      allow read: if (isOwner() && inMyTenant(resource.data))
        || (isTeacher() && inMyTenant(resource.data)
            && resource.data.get('classroomId', '') == userClassroom())
        || (isParent() && resource.data.childId in userChildIds());

      allow create: if planAllows('healthReports')
        && request.resource.data.daycareId == userDaycare()
        && request.resource.data.staffId == request.auth.uid
        && (
          (isOwner() && request.resource.data.daycareId == request.auth.uid)
          || (isTeacher() && request.resource.data.classroomId == userClassroom())
        );

      allow update, delete: if isOwner() && inMyTenant(resource.data);
    }

    // -------------------------------------------------------------------------
    // weeklyPlans/{planId} — teacher curriculum plan (Sprint 7 / D6)
    // -------------------------------------------------------------------------
    match /weeklyPlans/{planId} {
      allow read: if inMyTenant(resource.data)
        && (
          isOwner()
          || (isTeacher() && resource.data.classroomId == userClassroom())
          // Parents see their child's classroom plan, read-only.
          || isParent()
        );

      allow create: if planAllows('weeklyPlanner')
        && request.resource.data.daycareId == userDaycare()
        && (
          (isOwner() && request.resource.data.daycareId == request.auth.uid)
          || (isTeacher() && request.resource.data.classroomId == userClassroom())
        );

      allow update: if planAllows('weeklyPlanner')
        && inMyTenant(resource.data)
        && (
          (isTeacher() && resource.data.classroomId == userClassroom())
          || isOwner()
        );

      allow delete: if isOwner() && inMyTenant(resource.data);
    }

    // -------------------------------------------------------------------------
    // activityTemplates/{templateId} — curriculum library (Sprint 7 / D7)
    // -------------------------------------------------------------------------
    match /activityTemplates/{templateId} {
      allow read: if inMyTenant(resource.data)
        && (isOwner() || isTeacher() || isParent());

      allow create: if planAllows('activityPlanner')
        && request.resource.data.daycareId == userDaycare()
        && request.resource.data.ownerId == request.auth.uid
        && (isOwner() || isTeacher());

      allow update, delete: if planAllows('activityPlanner')
        && inMyTenant(resource.data)
        && (isOwner() || resource.data.ownerId == request.auth.uid);
    }

    // -------------------------------------------------------------------------
    // screenings/{screeningId} — morning health screenings (Sprint 7 / D8)
    // -------------------------------------------------------------------------
    match /screenings/{screeningId} {
      allow read: if (isOwner() && inMyTenant(resource.data))
        || (isTeacher() && inMyTenant(resource.data)
            && resource.data.get('classroomId', '') == userClassroom())
        || (isParent() && resource.data.childId in userChildIds());

      allow create: if planAllows('morningScreenings')
        && request.resource.data.daycareId == userDaycare()
        && request.resource.data.staffId == request.auth.uid
        && (
          (isOwner() && request.resource.data.daycareId == request.auth.uid)
          || (isTeacher() && request.resource.data.classroomId == userClassroom())
        );

      // Parent can acknowledge their child's screening (digital sign-off).
      allow update: if inMyTenant(resource.data)
        && (
          isOwner()
          || (isTeacher() && resource.data.classroomId == userClassroom())
          || (
            isParent()
            && resource.data.childId in userChildIds()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'parentAcknowledged', 'acknowledgedAt'
            ])
          )
        );

      allow delete: if isOwner() && inMyTenant(resource.data);
    }

    // -------------------------------------------------------------------------
    // leads/{leadId} — inbound sales / pricing-page submissions (Sprint 3 / E2)
    // -------------------------------------------------------------------------
    //
    // Anyone (unauthenticated web visitors on the landing page) can create a
    // lead via the contact-sales serverless function. To prevent spam /
    // abuse of rules-based writes, we require a small set of required fields
    // and cap the message length. The kidshub-landing/api/contact-sales.js
    // endpoint sits in front of this anyway, but defense-in-depth is cheap.
    //
    // Reads, updates, and deletes are completely blocked — only our internal
    // tooling (Admin SDK / Firestore console) can touch leads once written.
    // This keeps PII out of reach of any compromised web client.
    //
    match /leads/{leadId} {
      allow create: if request.resource.data.keys().hasAll(['name', 'email', 'source', 'createdAt'])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 200
        && request.resource.data.email is string
        && request.resource.data.email.size() > 3
        && request.resource.data.email.size() <= 320
        && request.resource.data.source is string
        && request.resource.data.get('message', '') is string
        && request.resource.data.get('message', '').size() <= 2000
        && request.resource.data.get('tier', '') is string;

      allow read, update, delete: if false;
    }

    // -------------------------------------------------------------------------
    // Default deny
    // -------------------------------------------------------------------------
    //
    // Anything not matched above is denied. Catches typos, new collections
    // that haven't been explicitly allowed yet, and experimental writes
    // from admin scripts.
    //
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
